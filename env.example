# ── WhatsApp Cloud API ──────────────────────────────────────────────────────
# Get from: Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=my_secure_token   # You choose this — must match what you enter in Meta Console

# ── Google Gemini AI ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google Sheets ───────────────────────────────────────────────────────────
# GOOGLE_SHEET_ID: the long ID in your Sheet URL
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Leads

# Path to your downloaded service account JSON (relative to project root)
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json




WHATSAPP_DISPLAY_NUMBER=+1xxxxxxxx
WHATSAPP_DEEP_LINK=https://wa.me/91xxxxxxxxxx